module enhanced_analyzer_interface
    ! Enhanced analyzer interface for Issue #222
    !
    ! This module extends the basic semantic analyzer interface with enhanced
    ! capabilities including query interface, metadata system, configuration,
    ! lifecycle management, and various specialized analyzer types.
    
    use semantic_analyzer_base, only: semantic_analyzer_t
    use analyzer_results, only: analyzer_results_t
    use semantic_analyzer, only: semantic_context_t
    use ast_core, only: ast_arena_t
    use event_system, only: analysis_event_system_t, event_subscriber_t, &
                             node_event_data_t
    implicit none
    private
    
    public :: enhanced_semantic_analyzer_t, queryable_analyzer_t
    public :: lifecycle_aware_analyzer_t, configurable_analyzer_t
    public :: mock_semantic_analyzer_t, dependency_aware_analyzer_t
    public :: composite_analyzer_t, profiling_analyzer_t
    public :: thread_safe_analyzer_t, stateful_analyzer_t
    public :: analyzer_metadata_t, analyzer_config_t, semantic_query_t
    public :: query_result_t, analyzer_dependencies_t, progress_monitor_t
    public :: progress_report_t, diagnostic_context_t, analyzer_error_t
    public :: performance_profile_t, timing_breakdown_t, concurrency_info_t
    public :: analyzer_state_t, analyzer_registry_t, analyzer_validator_t
    public :: validation_report_t
    public :: create_analyzer_config, create_semantic_query
    public :: create_progress_monitor, create_analyzer_registry
    public :: create_analyzer_validator
    
    ! Version information
    type :: version_info_t
        integer :: major = 1
        integer :: minor = 0
        integer :: patch = 0
    end type version_info_t
    
    ! Analyzer metadata
    type :: analyzer_metadata_t
        character(len=256) :: name = ""
        character(len=512) :: description = ""
        type(version_info_t) :: version
        character(len=32), allocatable :: capabilities(:)
        character(len=32), allocatable :: requirements(:)
        character(len=256) :: author = ""
        character(len=256) :: contact = ""
    contains
        procedure :: get_capabilities => metadata_get_capabilities
        procedure :: get_requirements => metadata_get_requirements
    end type analyzer_metadata_t
    
    ! Analyzer configuration
    type :: analyzer_config_t
        character(len=256) :: config_data(100)  ! Key-value pairs
        logical :: bool_values(100)
        integer :: int_values(100)
        real :: real_values(100)
        integer :: data_count = 0
        logical :: is_valid = .false.
    contains
        procedure :: set_string => config_set_string
        procedure :: set_bool => config_set_bool
        procedure :: set_int => config_set_int
        procedure :: set_real => config_set_real
        procedure :: get_string => config_get_string
        procedure :: get_bool => config_get_bool
        procedure :: get_int => config_get_int
        procedure :: get_real => config_get_real
        ! Use specific method names to avoid ambiguity
    end type analyzer_config_t
    
    ! Semantic query
    type :: semantic_query_t
        character(len=256) :: query_type = ""
        character(len=256) :: target = ""
        character(len=512) :: parameters = ""
        logical :: is_valid = .false.
    end type semantic_query_t
    
    ! Query result
    type :: query_result_t
        character(len=256) :: query_type = ""
        character(len=256) :: source_analyzer = ""
        character(len=:), allocatable :: data
        logical :: success = .false.
        character(len=:), allocatable :: error_message
    contains
        procedure :: has_data => query_result_has_data
    end type query_result_t
    
    ! Analyzer dependencies
    type :: analyzer_dependencies_t
        character(len=256), allocatable :: required(:)
        character(len=256), allocatable :: optional(:)
    contains
        procedure :: get_required => deps_get_required
        procedure :: get_optional => deps_get_optional
        procedure :: has_requirements => deps_has_requirements
    end type analyzer_dependencies_t
    
    ! Progress monitoring
    type :: progress_report_t
        integer :: completion_percentage = 0
        integer :: total_steps = 0
        integer :: completed_steps = 0
        character(len=256) :: current_phase = ""
        logical :: is_completed = .false.
    end type progress_report_t
    
    type :: progress_monitor_t
        type(progress_report_t) :: reports(1000)
        integer :: num_updates = 0
        type(progress_report_t) :: final_report
    contains
        procedure :: update_count => monitor_update_count
        procedure :: get_final_report => monitor_get_final_report
    end type progress_monitor_t
    
    ! Error and diagnostic handling
    type :: analyzer_error_t
        character(len=256) :: message = ""
        character(len=32) :: severity = ""
        character(len=256) :: source_file = ""
        integer :: line_number = 0
        integer :: column_number = 0
    contains
        procedure :: has_location_info => error_has_location_info
    end type analyzer_error_t
    
    type :: diagnostic_context_t
        type(analyzer_error_t) :: errors(100)
        integer :: num_errors = 0
    contains
        procedure :: get_last_error => diagnostics_get_last_error
        procedure :: error_count => diagnostics_error_count
    end type diagnostic_context_t
    
    ! Performance profiling
    type :: timing_breakdown_t
        real, allocatable :: phase_times(:)
        character(len=32), allocatable :: phase_names(:)
    contains
        procedure :: has_detailed_breakdown => timing_has_breakdown
    end type timing_breakdown_t
    
    type :: performance_profile_t
        real :: total_execution_time_ms = 0.0
        real :: memory_peak_mb = 0.0
        type(timing_breakdown_t) :: timing_breakdown
    contains
        procedure :: get_timing_breakdown => profile_get_timing_breakdown
    end type performance_profile_t
    
    ! Thread safety and concurrency
    type :: concurrency_info_t
        integer :: max_concurrent_instances = 1
        logical :: sync_primitives = .false.
        character(len=256) :: thread_safety_notes = ""
    contains
        procedure :: has_synchronization_primitives => &
            concurrency_has_sync_primitives
    end type concurrency_info_t
    
    ! Analyzer state management
    type :: analyzer_state_t
        character(len=:), allocatable :: state_data
        logical :: valid = .false.
        integer :: version = 1
    contains
        procedure :: equals => state_equals
        procedure :: is_valid => state_is_valid
    end type analyzer_state_t
    
    ! Enhanced semantic analyzer interface
    type, abstract, extends(semantic_analyzer_t) :: enhanced_semantic_analyzer_t
    contains
        procedure :: supports_queries => enhanced_supports_queries
        procedure :: supports_lifecycle_management => &
            enhanced_supports_lifecycle
        procedure :: has_metadata_interface => enhanced_has_metadata_interface
        procedure :: is_interface_compliant => enhanced_is_interface_compliant
        procedure(get_metadata_interface), deferred :: get_metadata
    end type enhanced_semantic_analyzer_t
    
    ! Interface for metadata
    abstract interface
        function get_metadata_interface(this) result(metadata)
            import :: enhanced_semantic_analyzer_t, analyzer_metadata_t
            class(enhanced_semantic_analyzer_t), intent(in) :: this
            type(analyzer_metadata_t) :: metadata
        end function get_metadata_interface
    end interface
    
    ! Queryable analyzer interface
    type, abstract, extends(enhanced_semantic_analyzer_t) :: queryable_analyzer_t
    contains
        procedure(execute_query_interface), deferred :: execute_query
    end type queryable_analyzer_t
    
    ! Interface for query execution
    abstract interface
        function execute_query_interface(this, query, success) result(result)
            import :: queryable_analyzer_t, semantic_query_t, query_result_t
            class(queryable_analyzer_t), intent(inout) :: this
            type(semantic_query_t), intent(in) :: query
            logical, intent(out) :: success
            type(query_result_t) :: result
        end function execute_query_interface
    end interface
    
    ! Lifecycle-aware analyzer
    type, abstract, extends(enhanced_semantic_analyzer_t) :: &
        lifecycle_aware_analyzer_t
    contains
        procedure(initialize_interface), deferred :: initialize
        procedure(finalize_interface), deferred :: finalize
        procedure(is_initialized_interface), deferred :: is_initialized
        procedure(is_finalized_interface), deferred :: is_finalized
    end type lifecycle_aware_analyzer_t
    
    ! Lifecycle interfaces
    abstract interface
        function initialize_interface(this) result(success)
            import :: lifecycle_aware_analyzer_t
            class(lifecycle_aware_analyzer_t), intent(inout) :: this
            logical :: success
        end function initialize_interface
        
        function finalize_interface(this) result(success)
            import :: lifecycle_aware_analyzer_t
            class(lifecycle_aware_analyzer_t), intent(inout) :: this
            logical :: success
        end function finalize_interface
        
        function is_initialized_interface(this) result(initialized)
            import :: lifecycle_aware_analyzer_t
            class(lifecycle_aware_analyzer_t), intent(in) :: this
            logical :: initialized
        end function is_initialized_interface
        
        function is_finalized_interface(this) result(finalized)
            import :: lifecycle_aware_analyzer_t
            class(lifecycle_aware_analyzer_t), intent(in) :: this
            logical :: finalized
        end function is_finalized_interface
    end interface
    
    ! Configurable analyzer
    type, abstract, extends(enhanced_semantic_analyzer_t) :: &
        configurable_analyzer_t
    contains
        procedure(validate_config_interface), deferred :: validate_config
        procedure(configure_interface), deferred :: configure
        procedure(is_configured_interface), deferred :: is_configured
        procedure(get_config_interface), deferred :: get_config
    end type configurable_analyzer_t
    
    ! Configuration interfaces
    abstract interface
        function validate_config_interface(this, config) result(valid)
            import :: configurable_analyzer_t, analyzer_config_t
            class(configurable_analyzer_t), intent(in) :: this
            type(analyzer_config_t), intent(in) :: config
            logical :: valid
        end function validate_config_interface
        
        function configure_interface(this, config) result(success)
            import :: configurable_analyzer_t, analyzer_config_t
            class(configurable_analyzer_t), intent(inout) :: this
            type(analyzer_config_t), intent(in) :: config
            logical :: success
        end function configure_interface
        
        function is_configured_interface(this) result(configured)
            import :: configurable_analyzer_t
            class(configurable_analyzer_t), intent(in) :: this
            logical :: configured
        end function is_configured_interface
        
        function get_config_interface(this) result(config)
            import :: configurable_analyzer_t, analyzer_config_t
            class(configurable_analyzer_t), intent(in) :: this
            type(analyzer_config_t) :: config
        end function get_config_interface
    end interface
    
    ! Mock analyzer for testing
    type, extends(enhanced_semantic_analyzer_t) :: mock_semantic_analyzer_t
        logical :: analysis_result = .true.
        character(len=:), allocatable :: result_data
        real :: execution_time_ms = 0.0
        integer :: call_counts(10) = 0  ! Track method calls
        character(len=32) :: method_names(10)
        integer :: method_count = 0
    contains
        procedure :: analyze => mock_analyze
        procedure :: get_results => mock_get_results
        procedure :: get_metadata => mock_get_metadata
        procedure :: set_analysis_result => mock_set_analysis_result
        procedure :: set_result_data => mock_set_result_data
        procedure :: set_execution_time_ms => mock_set_execution_time_ms
        procedure :: call_count => mock_call_count
    end type mock_semantic_analyzer_t
    
    ! Dependency-aware analyzer
    type, abstract, extends(enhanced_semantic_analyzer_t) :: &
        dependency_aware_analyzer_t
    contains
        procedure(get_dependencies_interface), deferred :: get_dependencies
    end type dependency_aware_analyzer_t
    
    ! Dependencies interface
    abstract interface
        function get_dependencies_interface(this) result(dependencies)
            import :: dependency_aware_analyzer_t, analyzer_dependencies_t
            class(dependency_aware_analyzer_t), intent(in) :: this
            type(analyzer_dependencies_t) :: dependencies
        end function get_dependencies_interface
    end interface
    
    ! Composite analyzer
    type, extends(enhanced_semantic_analyzer_t) :: composite_analyzer_t
        class(enhanced_semantic_analyzer_t), allocatable :: sub_analyzers(:)
        character(len=256), allocatable :: sub_analyzer_names(:)
        integer :: num_sub_analyzers = 0
        type(analyzer_results_t), allocatable :: sub_results(:)
    contains
        procedure :: analyze => composite_analyze
        procedure :: get_results => composite_get_results
        procedure :: get_metadata => composite_get_metadata
        procedure :: add_sub_analyzer => composite_add_sub_analyzer
        procedure :: sub_analyzer_count => composite_sub_analyzer_count
        procedure :: all_sub_analyzers_succeeded => &
            composite_all_sub_analyzers_succeeded
        procedure :: has_sub_analyzer_results => &
            composite_has_sub_analyzer_results
    end type composite_analyzer_t
    
    ! Profiling analyzer
    type, abstract, extends(enhanced_semantic_analyzer_t) :: profiling_analyzer_t
        logical :: profiling_enabled = .false.
        type(performance_profile_t) :: profile
    contains
        procedure :: enable_profiling => profiling_enable_profiling
        procedure :: get_performance_profile => profiling_get_performance_profile
    end type profiling_analyzer_t
    
    ! Thread-safe analyzer
    type, abstract, extends(enhanced_semantic_analyzer_t) :: &
        thread_safe_analyzer_t
    contains
        procedure :: is_thread_safe => thread_safe_is_thread_safe
        procedure :: supports_concurrent_analysis => &
            thread_safe_supports_concurrent_analysis
        procedure(get_concurrency_info_interface), deferred :: &
            get_concurrency_info
    end type thread_safe_analyzer_t
    
    ! Concurrency info interface
    abstract interface
        function get_concurrency_info_interface(this) result(info)
            import :: thread_safe_analyzer_t, concurrency_info_t
            class(thread_safe_analyzer_t), intent(in) :: this
            type(concurrency_info_t) :: info
        end function get_concurrency_info_interface
    end interface
    
    ! Stateful analyzer
    type, abstract, extends(enhanced_semantic_analyzer_t) :: stateful_analyzer_t
    contains
        procedure(get_state_interface), deferred :: get_state
        procedure(reset_state_interface), deferred :: reset_state
        procedure :: is_state_isolated => stateful_is_state_isolated
    end type stateful_analyzer_t
    
    ! State interfaces
    abstract interface
        function get_state_interface(this) result(state)
            import :: stateful_analyzer_t, analyzer_state_t
            class(stateful_analyzer_t), intent(in) :: this
            type(analyzer_state_t) :: state
        end function get_state_interface
        
        subroutine reset_state_interface(this)
            import :: stateful_analyzer_t
            class(stateful_analyzer_t), intent(inout) :: this
        end subroutine reset_state_interface
    end interface
    
    ! Analyzer registry
    type :: analyzer_registry_t
        character(len=256) :: analyzer_names(100)
        integer :: analyzer_count = 0
    contains
        procedure :: register_analyzer_type => registry_register_analyzer_type
        procedure :: list_available_analyzers => &
            registry_list_available_analyzers
        procedure :: create_analyzer => registry_create_analyzer
    end type analyzer_registry_t
    
    ! Analyzer validator
    type :: validation_report_t
        logical :: valid = .false.
        integer :: num_tests = 0
        integer :: num_passed = 0
        character(len=:), allocatable :: summary_text
    contains
        procedure :: is_valid => report_is_valid
        procedure :: passes_compliance_tests => report_passes_compliance_tests
        procedure :: test_count => report_test_count
        procedure :: passed_tests => report_passed_tests
        procedure :: summary => report_summary
    end type validation_report_t
    
    type :: analyzer_validator_t
    contains
        procedure :: validate_analyzer => validator_validate_analyzer
    end type analyzer_validator_t
    
contains
    
    ! Factory functions
    
    function create_analyzer_config() result(config)
        type(analyzer_config_t) :: config
        
        config%data_count = 0
        config%is_valid = .true.
    end function create_analyzer_config
    
    function create_semantic_query(query_type, target) result(query)
        character(len=*), intent(in) :: query_type
        character(len=*), optional, intent(in) :: target
        type(semantic_query_t) :: query
        
        query%query_type = trim(query_type)
        if (present(target)) then
            query%target = trim(target)
        end if
        query%is_valid = .true.
    end function create_semantic_query
    
    function create_progress_monitor() result(monitor)
        type(progress_monitor_t) :: monitor
        
        monitor%num_updates = 0
        monitor%final_report%completion_percentage = 0
        monitor%final_report%is_completed = .false.
    end function create_progress_monitor
    
    function create_analyzer_registry() result(registry)
        type(analyzer_registry_t) :: registry
        
        registry%analyzer_count = 0
    end function create_analyzer_registry
    
    function create_analyzer_validator() result(validator)
        type(analyzer_validator_t) :: validator
        
        ! Validator has no state to initialize
    end function create_analyzer_validator
    
    ! Enhanced analyzer methods
    
    function enhanced_supports_queries(this) result(supports)
        class(enhanced_semantic_analyzer_t), intent(in) :: this
        logical :: supports
        
        ! Default implementation - override in concrete classes
        supports = .false.
    end function enhanced_supports_queries
    
    function enhanced_supports_lifecycle(this) result(supports)
        class(enhanced_semantic_analyzer_t), intent(in) :: this
        logical :: supports
        
        ! Default implementation - override in concrete classes
        supports = .false.
    end function enhanced_supports_lifecycle
    
    function enhanced_has_metadata_interface(this) result(has_interface)
        class(enhanced_semantic_analyzer_t), intent(in) :: this
        logical :: has_interface
        
        ! All enhanced analyzers must implement metadata interface
        has_interface = .true.
    end function enhanced_has_metadata_interface
    
    function enhanced_is_interface_compliant(this) result(compliant)
        class(enhanced_semantic_analyzer_t), intent(in) :: this
        logical :: compliant
        
        ! Check basic compliance requirements
        compliant = this%has_metadata_interface()
    end function enhanced_is_interface_compliant
    
    ! Metadata methods
    
    function metadata_get_capabilities(this) result(capabilities)
        class(analyzer_metadata_t), intent(in) :: this
        character(len=32), allocatable :: capabilities(:)
        
        if (allocated(this%capabilities)) then
            capabilities = this%capabilities
        else
            allocate(capabilities(0))
        end if
    end function metadata_get_capabilities
    
    function metadata_get_requirements(this) result(requirements)
        class(analyzer_metadata_t), intent(in) :: this
        character(len=32), allocatable :: requirements(:)
        
        if (allocated(this%requirements)) then
            requirements = this%requirements
        else
            allocate(requirements(0))
        end if
    end function metadata_get_requirements
    
    ! Configuration methods
    
    subroutine config_set_string(this, key, value)
        class(analyzer_config_t), intent(inout) :: this
        character(len=*), intent(in) :: key
        character(len=*), intent(in) :: value
        
        if (this%data_count < 100) then
            this%data_count = this%data_count + 1
            this%config_data(this%data_count) = trim(key) // "=" // trim(value)
        end if
    end subroutine config_set_string
    
    subroutine config_set_bool(this, key, value)
        class(analyzer_config_t), intent(inout) :: this
        character(len=*), intent(in) :: key
        logical, intent(in) :: value
        
        if (this%data_count < 100) then
            this%data_count = this%data_count + 1
            this%bool_values(this%data_count) = value
            if (value) then
                this%config_data(this%data_count) = trim(key) // "=true"
            else
                this%config_data(this%data_count) = trim(key) // "=false"
            end if
        end if
    end subroutine config_set_bool
    
    subroutine config_set_int(this, key, value)
        class(analyzer_config_t), intent(inout) :: this
        character(len=*), intent(in) :: key
        integer, intent(in) :: value
        
        if (this%data_count < 100) then
            this%data_count = this%data_count + 1
            this%int_values(this%data_count) = value
            write(this%config_data(this%data_count), '(A,A,I0)') &
                trim(key), "=", value
        end if
    end subroutine config_set_int
    
    subroutine config_set_real(this, key, value)
        class(analyzer_config_t), intent(inout) :: this
        character(len=*), intent(in) :: key
        real, intent(in) :: value
        
        if (this%data_count < 100) then
            this%data_count = this%data_count + 1
            this%real_values(this%data_count) = value
            write(this%config_data(this%data_count), '(A,A,F0.3)') &
                trim(key), "=", value
        end if
    end subroutine config_set_real
    
    function config_get_string(this, key) result(value)
        class(analyzer_config_t), intent(in) :: this
        character(len=*), intent(in) :: key
        character(len=:), allocatable :: value
        integer :: i, eq_pos
        
        value = ""
        do i = 1, this%data_count
            eq_pos = index(this%config_data(i), "=")
            if (eq_pos > 0) then
                if (trim(this%config_data(i)(1:eq_pos-1)) == trim(key)) then
                    value = trim(this%config_data(i)(eq_pos+1:))
                    return
                end if
            end if
        end do
    end function config_get_string
    
    function config_get_bool(this, key) result(value)
        class(analyzer_config_t), intent(in) :: this
        character(len=*), intent(in) :: key
        logical :: value
        integer :: i, eq_pos
        
        value = .false.
        do i = 1, this%data_count
            eq_pos = index(this%config_data(i), "=")
            if (eq_pos > 0) then
                if (trim(this%config_data(i)(1:eq_pos-1)) == trim(key)) then
                    value = this%bool_values(i)
                    return
                end if
            end if
        end do
    end function config_get_bool
    
    function config_get_int(this, key) result(value)
        class(analyzer_config_t), intent(in) :: this
        character(len=*), intent(in) :: key
        integer :: value
        integer :: i, eq_pos
        
        value = 0
        do i = 1, this%data_count
            eq_pos = index(this%config_data(i), "=")
            if (eq_pos > 0) then
                if (trim(this%config_data(i)(1:eq_pos-1)) == trim(key)) then
                    value = this%int_values(i)
                    return
                end if
            end if
        end do
    end function config_get_int
    
    function config_get_real(this, key) result(value)
        class(analyzer_config_t), intent(in) :: this
        character(len=*), intent(in) :: key
        real :: value
        integer :: i, eq_pos
        
        value = 0.0
        do i = 1, this%data_count
            eq_pos = index(this%config_data(i), "=")
            if (eq_pos > 0) then
                if (trim(this%config_data(i)(1:eq_pos-1)) == trim(key)) then
                    value = this%real_values(i)
                    return
                end if
            end if
        end do
    end function config_get_real
    
    ! Query result methods
    
    function query_result_has_data(this) result(has_data)
        class(query_result_t), intent(in) :: this
        logical :: has_data
        
        has_data = allocated(this%data)
    end function query_result_has_data
    
    ! Dependencies methods
    
    function deps_get_required(this) result(required)
        class(analyzer_dependencies_t), intent(in) :: this
        character(len=256), allocatable :: required(:)
        
        if (allocated(this%required)) then
            required = this%required
        else
            allocate(required(0))
        end if
    end function deps_get_required
    
    function deps_get_optional(this) result(optional)
        class(analyzer_dependencies_t), intent(in) :: this
        character(len=256), allocatable :: optional(:)
        
        if (allocated(this%optional)) then
            optional = this%optional
        else
            allocate(optional(0))
        end if
    end function deps_get_optional
    
    function deps_has_requirements(this) result(has_reqs)
        class(analyzer_dependencies_t), intent(in) :: this
        logical :: has_reqs
        
        has_reqs = allocated(this%required) .and. (size(this%required) > 0)
    end function deps_has_requirements
    
    ! Progress monitor methods
    
    function monitor_update_count(this) result(count)
        class(progress_monitor_t), intent(in) :: this
        integer :: count
        
        count = this%num_updates
    end function monitor_update_count
    
    function monitor_get_final_report(this) result(report)
        class(progress_monitor_t), intent(in) :: this
        type(progress_report_t) :: report
        
        report = this%final_report
    end function monitor_get_final_report
    
    ! Error and diagnostic methods
    
    function error_has_location_info(this) result(has_location)
        class(analyzer_error_t), intent(in) :: this
        logical :: has_location
        
        has_location = (this%line_number > 0) .and. (this%column_number > 0)
    end function error_has_location_info
    
    function diagnostics_get_last_error(this) result(error)
        class(diagnostic_context_t), intent(in) :: this
        type(analyzer_error_t) :: error
        
        if (this%num_errors > 0) then
            error = this%errors(this%num_errors)
        else
            error%message = "No errors recorded"
            error%severity = "info"
        end if
    end function diagnostics_get_last_error
    
    function diagnostics_error_count(this) result(count)
        class(diagnostic_context_t), intent(in) :: this
        integer :: count
        
        count = this%num_errors
    end function diagnostics_error_count
    
    ! Performance profiling methods
    
    function timing_has_breakdown(this) result(has_breakdown)
        class(timing_breakdown_t), intent(in) :: this
        logical :: has_breakdown
        
        has_breakdown = allocated(this%phase_times) .and. &
                       allocated(this%phase_names)
    end function timing_has_breakdown
    
    function profile_get_timing_breakdown(this) result(timing)
        class(performance_profile_t), intent(in) :: this
        type(timing_breakdown_t) :: timing
        
        timing = this%timing_breakdown
    end function profile_get_timing_breakdown
    
    ! Concurrency methods
    
    function concurrency_has_sync_primitives(this) result(has_sync)
        class(concurrency_info_t), intent(in) :: this
        logical :: has_sync
        
        has_sync = this%sync_primitives
    end function concurrency_has_sync_primitives
    
    ! State management methods
    
    function state_equals(this, other) result(equal)
        class(analyzer_state_t), intent(in) :: this
        type(analyzer_state_t), intent(in) :: other
        logical :: equal
        
        equal = .false.
        if (this%valid .and. other%valid) then
            if (allocated(this%state_data) .and. allocated(other%state_data)) then
                equal = (this%state_data == other%state_data) .and. &
                       (this%version == other%version)
            end if
        end if
    end function state_equals
    
    function state_is_valid(this) result(valid)
        class(analyzer_state_t), intent(in) :: this
        logical :: valid
        
        valid = this%valid
    end function state_is_valid
    
    ! Mock analyzer implementation
    
    function mock_analyze(this, context, arena, root_index) result(success)
        class(mock_semantic_analyzer_t), intent(inout) :: this
        type(semantic_context_t), intent(inout) :: context
        type(ast_arena_t), intent(inout) :: arena
        integer, intent(in) :: root_index
        logical :: success
        
        call record_method_call(this, "analyze")
        success = this%analysis_result
    end function mock_analyze
    
    function mock_get_results(this) result(results)
        class(mock_semantic_analyzer_t), intent(in) :: this
        type(analyzer_results_t) :: results
        
        results%analyzer_name = "mock_analyzer"
        results%success = this%analysis_result
        results%has_data = allocated(this%result_data)
        if (allocated(this%result_data)) then
            results%data = this%result_data
        end if
    end function mock_get_results
    
    function mock_get_metadata(this) result(metadata)
        class(mock_semantic_analyzer_t), intent(in) :: this
        type(analyzer_metadata_t) :: metadata
        
        metadata%name = "Mock Semantic Analyzer"
        metadata%description = "Test analyzer for unit testing"
        metadata%version%major = 1
        metadata%version%minor = 0
        metadata%version%patch = 0
        allocate(metadata%capabilities(1))
        metadata%capabilities(1) = "mock_analysis"
    end function mock_get_metadata
    
    subroutine mock_set_analysis_result(this, result)
        class(mock_semantic_analyzer_t), intent(inout) :: this
        logical, intent(in) :: result
        
        this%analysis_result = result
    end subroutine mock_set_analysis_result
    
    subroutine mock_set_result_data(this, data)
        class(mock_semantic_analyzer_t), intent(inout) :: this
        character(len=*), intent(in) :: data
        
        this%result_data = trim(data)
    end subroutine mock_set_result_data
    
    subroutine mock_set_execution_time_ms(this, time_ms)
        class(mock_semantic_analyzer_t), intent(inout) :: this
        real, intent(in) :: time_ms
        
        this%execution_time_ms = time_ms
    end subroutine mock_set_execution_time_ms
    
    function mock_call_count(this, method_name) result(count)
        class(mock_semantic_analyzer_t), intent(in) :: this
        character(len=*), intent(in) :: method_name
        integer :: count
        integer :: i
        
        count = 0
        do i = 1, this%method_count
            if (trim(this%method_names(i)) == trim(method_name)) then
                count = this%call_counts(i)
                return
            end if
        end do
    end function mock_call_count
    
    subroutine record_method_call(this, method_name)
        class(mock_semantic_analyzer_t), intent(inout) :: this
        character(len=*), intent(in) :: method_name
        integer :: i
        
        ! Find existing method or add new one
        do i = 1, this%method_count
            if (trim(this%method_names(i)) == trim(method_name)) then
                this%call_counts(i) = this%call_counts(i) + 1
                return
            end if
        end do
        
        ! Add new method
        if (this%method_count < 10) then
            this%method_count = this%method_count + 1
            this%method_names(this%method_count) = trim(method_name)
            this%call_counts(this%method_count) = 1
        end if
    end subroutine record_method_call
    
    ! Composite analyzer implementation
    
    function composite_analyze(this, context, arena, root_index) result(success)
        class(composite_analyzer_t), intent(inout) :: this
        type(semantic_context_t), intent(inout) :: context
        type(ast_arena_t), intent(inout) :: arena
        integer, intent(in) :: root_index
        logical :: success
        integer :: i
        logical :: sub_success
        
        success = .true.
        
        ! Allocate results array
        if (.not. allocated(this%sub_results)) then
            allocate(this%sub_results(this%num_sub_analyzers))
        end if
        
        ! Simplified implementation - just return success for now
        ! In a real implementation, would execute actual sub-analyzers
        success = .true.
    end function composite_analyze
    
    function composite_get_results(this) result(results)
        class(composite_analyzer_t), intent(in) :: this
        type(analyzer_results_t) :: results
        
        results%analyzer_name = "composite_analyzer"
        results%success = this%all_sub_analyzers_succeeded()
        results%has_data = .true.
        results%data = "composite analysis complete"
    end function composite_get_results
    
    function composite_get_metadata(this) result(metadata)
        class(composite_analyzer_t), intent(in) :: this
        type(analyzer_metadata_t) :: metadata
        
        metadata%name = "Composite Analyzer"
        metadata%description = "Coordinates multiple sub-analyzers"
        metadata%version%major = 1
        metadata%version%minor = 0
        metadata%version%patch = 0
        allocate(metadata%capabilities(1))
        metadata%capabilities(1) = "composite_analysis"
    end function composite_get_metadata
    
    subroutine composite_add_sub_analyzer(this, analyzer, name)
        class(composite_analyzer_t), intent(inout) :: this
        class(enhanced_semantic_analyzer_t), intent(in) :: analyzer
        character(len=*), intent(in) :: name
        
        ! Simple implementation - just track count for now
        ! In a real implementation, would need to handle storage differently
        this%num_sub_analyzers = this%num_sub_analyzers + 1
        
        ! For simplicity in this implementation, just store the names
        if (.not. allocated(this%sub_analyzer_names)) then
            allocate(this%sub_analyzer_names(1))
            this%sub_analyzer_names(1) = trim(name)
        end if
    end subroutine composite_add_sub_analyzer
    
    function composite_sub_analyzer_count(this) result(count)
        class(composite_analyzer_t), intent(in) :: this
        integer :: count
        
        count = this%num_sub_analyzers
    end function composite_sub_analyzer_count
    
    function composite_all_sub_analyzers_succeeded(this) result(all_succeeded)
        class(composite_analyzer_t), intent(in) :: this
        logical :: all_succeeded
        integer :: i
        
        all_succeeded = .true.
        if (allocated(this%sub_results)) then
            do i = 1, this%num_sub_analyzers
                if (.not. this%sub_results(i)%success) then
                    all_succeeded = .false.
                    return
                end if
            end do
        end if
    end function composite_all_sub_analyzers_succeeded
    
    function composite_has_sub_analyzer_results(this) result(has_results)
        class(composite_analyzer_t), intent(in) :: this
        logical :: has_results
        
        has_results = allocated(this%sub_results) .and. &
                     (this%num_sub_analyzers > 0)
    end function composite_has_sub_analyzer_results
    
    ! Profiling analyzer methods
    
    subroutine profiling_enable_profiling(this, enabled)
        class(profiling_analyzer_t), intent(inout) :: this
        logical, intent(in) :: enabled
        
        this%profiling_enabled = enabled
    end subroutine profiling_enable_profiling
    
    function profiling_get_performance_profile(this) result(profile)
