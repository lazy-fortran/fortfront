    function thread_safe_is_thread_safe(this) result(is_safe)
        class(thread_safe_analyzer_t), intent(in) :: this
        logical :: is_safe
        
        is_safe = .true.  ! Default implementation
    end function thread_safe_is_thread_safe
    
    function thread_safe_supports_concurrent_analysis(this) result(supports)
        class(thread_safe_analyzer_t), intent(in) :: this
