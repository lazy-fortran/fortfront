program test_debug_literal
use core_type_analyzer_module, only: core_type_analyzer_t
use lexer_core, only: tokenize_core, token_t
use parser_dispatcher_module, only: parse_statement_dispatcher
use ast_core, only: ast_arena_t, create_ast_arena, literal_node
use semantic_analyzer, only: semantic_context_t, create_semantic_context
use type_system_hm, only: TINT
implicit none
type(token_t), allocatable :: tokens(:)
type(ast_arena_t) :: arena
type(semantic_context_t) :: context
type(core_type_analyzer_t) :: analyzer
integer :: expr_index
character(len=*), parameter :: test_source = "42"

print *, "Testing literal: ", test_source
call tokenize_core(test_source, tokens)
arena = create_ast_arena()
expr_index = parse_statement_dispatcher(tokens, arena)
print *, "Parse result, expr_index = ", expr_index

if (expr_index > 0) then
    context = create_semantic_context()
    select type (expr => arena%entries(expr_index)%node)
    type is (literal_node)
        block
            use type_system_hm, only: mono_type_t
            type(mono_type_t) :: result_type
            result_type = analyzer%infer_literal(expr)
            print *, "Literal type kind: ", result_type%kind
            print *, "Expected TINT (2): ", TINT
        end block
    class default
        print *, "Not a literal node"
    end select
else
    print *, "Parse failed"
end if
end program
